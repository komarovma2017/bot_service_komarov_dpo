# Auth Service — переменные окружения
# ВАЖНО: скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Название сервиса (для логов)
APP_NAME=auth-service

# Окружение: local | staging | production
ENV=local

# JWT настройки — ОБЯЗАТЕЛЬНО поменять JWT_SECRET!
# Этот же секрет должен быть в bot_service/.env
JWT_SECRET=change_me_super_secret_minimum_32_chars
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# База данных SQLite (путь к файлу)
SQLITE_PATH=./auth.db
