# Bot Service — переменные окружения
# ВАЖНО: скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Название сервиса (для логов)
APP_NAME=bot-service

# Окружение: local | staging | production
ENV=local

# Telegram Bot Token — получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# JWT настройки — ДОЛЖНЫ СОВПАДАТЬ с auth_service/.env !
JWT_SECRET=change_me_super_secret_minimum_32_chars
JWT_ALG=HS256

# Redis — в docker-compose используем имя сервиса "redis"
REDIS_URL=redis://redis:6379/0

# RabbitMQ — в docker-compose используем имя сервиса "rabbitmq"
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# OpenRouter API — получить ключ на openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=bot-service
